# Travel Companion — agent runtime env. Copy to .env (gitignored) on the VPS.
ANTHROPIC_API_KEY=sk-ant-...           # required — the model key, server-side only
COPILOT_MODEL=claude-sonnet-4-6        # optional — orchestration model
ALLOWED_ORIGIN=https://1owl.github.io  # comma-separated app origins allowed to call this
PORT=4141                              # optional
# COPILOT_ENDPOINT=/api/copilotkit     # optional — must match VITE_COPILOT_RUNTIME_URL's path
# COPILOTKIT_TELEMETRY_DISABLED=true   # default; set false to re-enable
